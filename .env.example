# ── Database (Supabase PostgreSQL — Transaction Pooler, port 6543) ────────────
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:YOUR_PASSWORD@aws-1-ca-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# ── Supabase (fill in from Supabase Dashboard → Project Settings → API) ───────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Anthropic (fill in from console.anthropic.com → API Keys) ─────────────────
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ── Resend (fill in from resend.com → API Keys) ───────────────────────────────
RESEND_API_KEY=re_your-key-here

# ── Vercel Cron (any random secret string you choose) ─────────────────────────
CRON_SECRET=some-random-secret-string

# ── App URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Super Admin (for reference — real account created via Supabase Dashboard) ──
SUPER_ADMIN_EMAIL=superadmin@servemytable.ca
SUPER_ADMIN_PASSWORD=your-super-admin-password
